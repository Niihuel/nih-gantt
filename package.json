{
  "name": "nih-gantt",
  "version": "0.1.2",
  "description": "Lightweight SVG Gantt chart for React — frappe-gantt inspired, zero UI dependencies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "date-fns": ">=3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "date-fns": "^4.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0"
  },
  "keywords": [
    "gantt",
    "gantt-chart",
    "react",
    "svg",
    "timeline",
    "project-management",
    "scheduling",
    "frappe-gantt",
    "tailwindcss"
  ],
  "author": "Nihuel Prieto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/niihuel/nih-gantt"
  },
  "homepage": "https://github.com/niihuel/nih-gantt#readme",
  "bugs": {
    "url": "https://github.com/niihuel/nih-gantt/issues"
  }
}
